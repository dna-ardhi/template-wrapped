{
  "name": "template-wrapped",
  "version": "1.0.0",
  "description": "Reusable React components for 9:16 vertical story templates",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run clean && npm run build:esm && npm run build:cjs",
    "build:esm": "tsc --project tsconfig.build.json --module ESNext --outDir dist/esm",
    "build:cjs": "tsc --project tsconfig.build.json --module CommonJS --outDir dist/cjs",
    "clean": "rd /s /q dist 2>nul || echo No dist folder",
    "prepare": "npm run build",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "keywords": [
    "react",
    "story",
    "template",
    "vertical",
    "9:16",
    "wrapped"
  ],
  "author": "dna-ardhi",
  "license": "MIT",
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^29.5.12",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "ts-jest": "^29.4.11",
    "typescript": "^5.5.4"
  }
}
